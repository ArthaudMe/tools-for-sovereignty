---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The first year of Tools for Sovereignty. Navigating the idea maze." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="scroll-spacer" id="scroll-spacer"></div>

    <div class="envelope-scene" id="scene">
      <div class="envelope-layer envelope-back" id="env-back">
        <img src="/envelope.png" alt="" />
      </div>

      <div class="letter" id="letter">
        <div class="letter-content" id="letter-content">
          <div class="letter-logo-spacer"></div>
          <slot />
          <div class="bottom-logos">
            <img src="/logo.png" alt="" class="bottom-logo-img" />
            <img src="/logo.png" alt="" class="bottom-logo-img" />
            <img src="/logo.png" alt="" class="bottom-logo-img" />
          </div>
        </div>
      </div>

      <div class="envelope-layer envelope-front" id="env-front">
        <img src="/envelope.png" alt="" />
      </div>
    </div>

    <script>
      const scrollSpacer = document.getElementById("scroll-spacer")!;
      const letter = document.getElementById("letter")!;
      const letterContent = document.getElementById("letter-content")!;
      const envBack = document.getElementById("env-back")!;
      const envFront = document.getElementById("env-front")!;

      const PULL_PX = 700;
      let envHeight = 0;
      let travelPx = 0;

      function measure() {
        const img = envBack.querySelector("img")!;
        envHeight = img.offsetHeight;
        travelPx = envHeight * 0.9;
        const contentH = letterContent.scrollHeight;
        scrollSpacer.style.height = `${PULL_PX + contentH}px`;
      }

      function update() {
        const scrollY = window.scrollY;
        const pull = Math.min(scrollY / PULL_PX, 1);

        if (pull < 1) {
          // Phase 1: letter slides UP, envelope slides DOWN
          const eased = 1 - Math.pow(1 - pull, 3);
          letter.style.transform = `translateY(${-eased * travelPx}px)`;

          // Envelope slides down progressively once text starts showing (~30%)
          const envSlide = pull > 0.3
            ? ((pull - 0.3) / 0.7) * envHeight * 1.2
            : 0;
          envBack.style.transform = `translate(-50%, calc(-45% + ${envSlide}px))`;
          envFront.style.transform = `translate(-50%, calc(-45% + ${envSlide}px))`;

          letterContent.style.transform = "translateY(0)";
        } else {
          // Phase 2: envelope gone, scroll content
          letter.style.transform = `translateY(${-travelPx}px)`;
          envBack.style.transform = `translate(-50%, 100%)`;
          envFront.style.transform = `translate(-50%, 100%)`;

          const contentScroll = scrollY - PULL_PX;
          letterContent.style.transform = `translateY(${-contentScroll}px)`;
        }
      }

      // Logo rotation
      const logos = document.querySelectorAll<HTMLImageElement>(".hero-logo");
      let rot = 0;
      let lastY = window.scrollY;

      // Chapter fade-in
      const obs = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) e.target.classList.add("visible");
        }),
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );

      function onScroll() {
        requestAnimationFrame(() => {
          update();
          const d = window.scrollY - lastY;
          rot += d * 0.5;
          logos.forEach((l) => { l.style.transform = `rotate(${rot}deg)`; });
          lastY = window.scrollY;
        });
      }

      function init() {
        measure();
        update();
        document.querySelectorAll(".chapter").forEach((el) => obs.observe(el));
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", () => { measure(); update(); });
      if (document.readyState === "complete") init();
      else window.addEventListener("load", init);
    </script>
  </body>
</html>
